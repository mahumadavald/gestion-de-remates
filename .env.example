# Copiar este archivo como .env.local y completar los valores reales
# NUNCA subir .env.local al repositorio

# Supabase — cliente (expuesto al browser, prefijo NEXT_PUBLIC requerido)
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui

# Supabase — solo servidor (nunca exponer al browser)
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# Integración Remates Ahumada
AHUMADA_API_URL=https://www.rematesahumada.cl/gr-api.php
AHUMADA_API_TOKEN=tu_token_compartido_aqui

# Email (Resend — resend.com)
RESEND_API_KEY=re_tu_api_key_aqui

# IA (Anthropic — console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-tu_api_key_aqui
